{
    "name": "hansm/cb-vehicles",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.4",
        "wp-coding-standards/wpcs": "^3.0",
        "squizlabs/php_codesniffer": "^3.7",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "CBVehicles\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CBVehicles\\Tests\\": "tests/php"
        }
    },
    "authors": [
        {
            "name": "Hans Morbach",
            "email": "6433480+hansmorb@users.noreply.github.com"
        }
    ],
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
